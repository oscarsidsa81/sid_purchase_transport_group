<odoo>
    <record id="view_purchase_order_form_transport_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.transport.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/tree/field[@name='price_unit']" position="after">
                <field name="transport_hold"/>
                <field name="transport_state" widget="badge"/>
                <field name="qty_transport_assigned"/>
                <field name="qty_transport_available"/>
                <field name="transport_group_summary" string="Agrupaciones"/>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_line_form_transport_inherit" model="ir.ui.view">
        <field name="name">purchase.order.line.form.transport.inherit</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button type="object"
                            name="action_view_transport_group_lines"
                            class="oe_stat_button"
                            icon="fa-truck">
                        <field name="transport_group_count" string="Agrupaciones" widget="statinfo"/>
                    </button>
                </div>
                <group string="Transporte">
                    <group>
                        <field name="transport_hold"/>
                        <field name="transport_state" widget="badge"/>
                    </group>
                    <group>
                        <field name="qty_transport_assigned" readonly="1"/>
                        <field name="qty_transport_available" readonly="1"/>
                    </group>
                    <field name="transport_group_ids" widget="many2many_tags" readonly="1"/>
                    <field name="transport_group_summary" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="action_purchase_transport_group_wizard" model="ir.actions.act_window">
        <field name="name">Crear agrupación transporte</field>
        <field name="res_model">purchase.transport.group.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order_line"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>
