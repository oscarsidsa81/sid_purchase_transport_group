<odoo>
    <record id="view_purchase_transport_group_wizard_form" model="ir.ui.view">
        <field name="name">purchase.transport.group.wizard.form</field>
        <field name="model">purchase.transport.group.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear agrupación de transporte">
                <group>
                    <field name="group_mode"/>
                    <field name="group_id"
                           attrs="{'required': [('group_mode', '=', 'existing')], 'invisible': [('group_mode', '=', 'new')]}"/>
                    <field name="carrier_partner_id"
                           attrs="{'invisible': [('group_mode', '=', 'existing')]}"/>
                </group>
                <field name="line_ids" nolabel="1">
                    <tree>
                        <field name="purchase_order_id" readonly="1"/>
                        <field name="product_id" readonly="1"/>
                        <field name="name" readonly="1"/>
                        <field name="transport_state" readonly="1"/>
                        <field name="qty_available" readonly="1"/>
                        <field name="qty_to_assign"/>
                        <field name="transport_group_summary" readonly="1"/>
                        <field name="product_uom" readonly="1"/>
                        <field name="purchase_line_id" invisible="1"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_create_group" type="object" string="Crear agrupación" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
