<odoo>
    <record id="view_purchase_transport_group_tree" model="ir.ui.view">
        <field name="name">purchase.transport.group.tree</field>
        <field name="model">purchase.transport.group</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="state"/>
                <field name="carrier_partner_id"/>
                <field name="transport_purchase_id"/>
                <field name="line_count"/>
            </tree>
        </field>
    </record>

    <record id="view_purchase_transport_group_form" model="ir.ui.view">
        <field name="name">purchase.transport.group.form</field>
        <field name="model">purchase.transport.group</field>
        <field name="arch" type="xml">
            <form string="Agrupación transporte">
                <header>
                    <button name="action_activate" type="object" string="Activar" states="draft" class="oe_highlight"/>
                    <button name="action_done" type="object" string="Finalizar" states="draft,active"/>
                    <button name="action_reset_draft" type="object" string="Volver a borrador" states="active,done,cancel"/>
                    <button name="action_cancel" type="object" string="Cancelar" states="draft,active,done"/>
                    <button name="action_create_transport_purchase" type="object" string="Generar RFQ transporte" states="draft,active,done" class="oe_highlight"/>
                    <button name="action_view_transport_purchase" type="object" string="Ver RFQ transporte" attrs="{'invisible': [('transport_purchase_id', '=', False)]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="carrier_partner_id"/>
                            <field name="transport_purchase_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="line_count" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Líneas">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="purchase_order_id" readonly="1"/>
                                    <field name="partner_id" readonly="1"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="name" readonly="1"/>
                                    <field name="qty_po" readonly="1"/>
                                    <field name="qty_received" readonly="1"/>
                                    <field name="qty_available" readonly="1"/>
                                    <field name="qty_assigned"/>
                                    <field name="qty_done"/>
                                    <field name="line_state"/>
                                    <field name="purchase_transport_state" readonly="1"/>
                                    <field name="purchase_line_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Resumen">
                            <field name="note_summary" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_purchase_transport_group" model="ir.actions.act_window">
        <field name="name">Agrupaciones transporte</field>
        <field name="res_model">purchase.transport.group</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('sid_purchase_transport_group.group_purchase_transport_user'))]"/>
    </record>

    <menuitem id="menu_purchase_transport_group_root"
              name="Agrupaciones transporte"
              parent="purchase.menu_purchase_root"
              action="action_purchase_transport_group"
              sequence="65"
              groups="sid_purchase_transport_group.group_purchase_transport_user"/>
</odoo>
